{
    "manifest_version": 3,
    "name": "おはツイKeeper",
    "version": "2.0",
    "description": "X(旧Twitter)のページからワンクリックでおはツイを登録。ストリークや統計もポップアップで確認できます。",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://ohatwikeeper.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "options_page": "options.html",
    "icons": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    }
}
